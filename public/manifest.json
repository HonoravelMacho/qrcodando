{
  "manifest_version": 3,
  "name": "Qrcodando",
  "version": "1.0.3",
  "description": "Estúdio de Design de QR Code Artístico e Customizável.",
  "permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Qrcodando",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
